# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY= 

# ── Optional (override defaults) ─────────────────────────────────────────────

# URL where the MCP search server is reachable from the backend container
# Default: http://mcp-server:8001/sse  (matches docker-compose service name)
MCP_SERVER_URL=http://mcp-server:8001/sse

# FastAPI port
PORT=8000

# MCP server port
MCP_SERVER_PORT=8001

# "development" enables uvicorn hot-reload
ENV=production
